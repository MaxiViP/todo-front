{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
      "@/*": ["./app/*"],
      "#app": [".nuxt/imports"], // добавлено для TypeScript
      "#imports": [".nuxt/imports"] // добавлено для TS глобальных функций
    },
    "types": [
      "@types/node",
      "@nuxt/schema" // добавляет типы Nuxt 4
    ]
  },
  "include": ["types/**/*.d.ts", "app/**/*", ".nuxt"]
}
